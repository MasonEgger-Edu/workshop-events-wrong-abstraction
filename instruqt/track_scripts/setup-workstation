#!/bin/bash
# ABOUTME: Track-level setup script for the Instruqt workstation VM.
# Pulls sandbox image, extracts assets + uv cache, installs tools, starts Temporal.
set -euxo pipefail

IMAGE="ghcr.io/masonegger-edu/workshop-events-wrong-abstraction:latest"

# -------------------------------------------------------------------
# 1. Pull sandbox image and extract assets + uv cache
# -------------------------------------------------------------------
docker pull "$IMAGE"
docker create --name tmp-sandbox "$IMAGE"
docker cp tmp-sandbox:/opt/assets /root/assets
docker cp tmp-sandbox:/root/.cache/uv /root/.cache/uv
docker rm tmp-sandbox

# Move projects to their final locations
mv /root/assets/durable-vs-normal-execution /root/durable-vs-normal-execution
mv /root/assets/durable-wordle /root/durable-wordle
rm -rf /root/assets

# -------------------------------------------------------------------
# 2. Install uv (Python package manager)
# -------------------------------------------------------------------
curl -LsSf https://astral.sh/uv/install.sh | sh
export PATH="/root/.local/bin:$PATH"

uv --version

# -------------------------------------------------------------------
# 3. Install Temporal CLI
# -------------------------------------------------------------------
curl -sSf https://temporal.download/cli.sh | sh
export PATH="/root/.temporalio/bin:$PATH"

temporal --version

# -------------------------------------------------------------------
# 4. Make PATH changes persistent for the learner
# -------------------------------------------------------------------
cat >> /root/.bashrc << 'PATHS'
export PATH="/root/.local/bin:/root/.temporalio/bin:$PATH"
PATHS

# -------------------------------------------------------------------
# 5. Install deps (fast — uv cache is pre-warmed from the image)
# -------------------------------------------------------------------
cd /root/durable-vs-normal-execution/durable
uv sync

cd /root/durable-vs-normal-execution/normal
uv sync

cd /root/durable-wordle
uv sync --frozen

# -------------------------------------------------------------------
# 6. Install and start code-server (VS Code in browser)
# -------------------------------------------------------------------
curl -fsSL https://code-server.dev/install.sh | sh

mkdir -p /root/.local/share/code-server/User
cat > /root/.local/share/code-server/User/settings.json << 'EOF'
{
    "workbench.colorTheme": "Default Dark+",
    "workbench.startupEditor": "none",
    "security.workspace.trust.enabled": false,
    "editor.fontSize": 14
}
EOF

cat > /etc/systemd/system/code-server.service << 'EOF'
[Unit]
Description=Code Server
After=network.target

[Service]
Type=simple
Restart=always
User=root
ExecStart=/usr/bin/code-server --host 0.0.0.0 --port 8443 --cert --auth none

[Install]
WantedBy=multi-user.target
EOF

systemctl enable code-server
systemctl start code-server

# -------------------------------------------------------------------
# 7. Start Temporal dev server (systemd, restarts on failure)
# -------------------------------------------------------------------
cat > /etc/systemd/system/temporal-server.service << 'EOF'
[Unit]
Description=Temporal Dev Server
After=network.target

[Service]
Type=simple
User=root
ExecStart=/root/.temporalio/bin/temporal server start-dev --ip 0.0.0.0 --db-filename /root/temporal.db
Restart=on-failure
RestartSec=5
StandardOutput=append:/root/temporal-server.log
StandardError=append:/root/temporal-server.log

[Install]
WantedBy=multi-user.target
EOF

systemctl enable temporal-server
systemctl start temporal-server

# Wait for Temporal server to be healthy
echo "Waiting for Temporal server..."
for attempt in $(seq 1 30); do
  if temporal operator cluster health --address 127.0.0.1:7233 2>/dev/null | grep -q SERVING; then
    echo "Temporal server healthy."
    break
  fi
  sleep 3
done

echo "=== Track setup complete ==="
